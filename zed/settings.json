{
  // disabled Editor Panels and Features
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_project_items": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "scrollbar": {
    "show": "auto",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "outline_panel": { "button": false },
  "collaboration_panel": { "button": false },
  "notification_panel": { "button": false },
  "gutter": {
    "folds": false,
    "runnables": false,
  },
  "disable_ai": true,

  // text Editing
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "auto_signature_help": true,
  "hover_popover_delay": 50,
  "line_indicator_format": "short",
  "format_on_save": "on",
  "tab_size": 4,
  "session": {
    "trust_all_worktrees": true,
  },

  // rullers and wrapping
  "wrap_guides": [80],
  "preferred_line_length": 80,
  "soft_wrap": "none",

  // visual
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "buffer_font_family": "Hack Nerd Font Mono",
  "relative_line_numbers": "enabled",
  "minimap": {
    "show": "always",
    "display_in": "all_editors",
    "thumb": "hover",
  },

  // debugger
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": false,
  },

  // terminal
  "terminal": {
    "button": false,
    "copy_on_select": true,
    "dock": "right",
    "toolbar": {
      "breadcrumbs": false,
    },
  },

  // language specific
  "languages": {
    "Markdown": {
      "wrap_guides": [80],
      "preferred_line_length": 80,
      "soft_wrap": "preferred_line_length",
    },
    "JSONC": {
      "wrap_guides": [120],
      "preferred_line_length": 120,
      "tab_size": 2,
    },
    "CSharp": {
      "wrap_guides": [120],
      "preferred_line_length": 120,
    },
    "Python": {
      // pyright is so much better
      "language_servers": ["!pylsp", "pyright"],
    },
  },
  "dap": {
    "lldb-dap": {
      "binary": "C:\\Program Files\\LLVM\\bin\\lldb-dap.exe",
    },
  },

  // Extensions
  "auto_install_extensions": {
    "html": true,
    "csharp": true,
    "vscode-dark-modern": true,
    "codebook": true,
    "symbols": true,
  },

  // custom visual assist color theme
  "theme": "VSCode Dark Modern",
  "icon_theme": "Symbols Icon Theme",
  "theme_overrides": {
    "VSCode Dark Modern": {
      "syntax": {
        // keywords
        "keyword": { "color": "#cf564d" },
        "keyword.operator": { "color": "#cf564d" },
        "namespace": { "color": "#c0ccb9" },
        "module": { "color": "#c0ccb9" },
        "attribute": { "color": "#c0ccb9" },

        // types
        "type": { "color": "#efd630" },
        "class": { "color": "#efd630" },
        "enum": { "color": "#efd630" },
        "interface": { "color": "#efd630" },
        "struct": { "color": "#efd630" },
        "typeParameter": { "color": "#efd630" },
        "boolean": { "color": "#b5cea8" },

        // string
        "punctuation.special": { "color": "#d4b273" },

        // functions
        "function": { "color": "#d37f2a" },
        "function.decorator": { "color": "#c0ccb9" },
        "method": { "color": "#d37f2a" },
        "constructor": { "color": "#d37f2a" },

        // constants
        "constant": { "color": "#936228" },
        "enumMember": { "color": "#936228" },
        "macro": { "color": "#b461c0" },

        // variables and fields
        "variable": { "color": "#b0b176" },
        "property": { "color": "#cdce87" },
        "parameter": { "color": "#b6a671" },
        "variable.special": { "color": "#cdce87" },

        // markdown
        "title": { "color": "#d37f2a", "font_style": "italic" },
        "emphasis.strong": { "color": "#cf564d" },
        "emphasis": { "font_style": "italic", "color": "#cf564d" },
        "text.literal": { "color": "#ce9178" },
        "punctuation.list_marker": { "color": "#d7ba7d" },
        "link_text": { "color": "#b5cea8" },
        "link_uri": { "color": "#c0ccb9", "font_style": "italic" },
      },
    },
  },
}
