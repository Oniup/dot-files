{
  // Disabled editor panels and features
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_project_items": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "scrollbar": {
    "show": "auto",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "outline_panel": {
    "dock": "left",
    "button": false,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "gutter": {
    "folds": false,
    "runnables": false,
  },
  "disable_ai": true,

  // Text editing
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "auto_signature_help": true,
  "line_indicator_format": "short",
  "format_on_save": "on",
  "tab_size": 4,
  "session": {
    "trust_all_worktrees": true,
  },

  // Rullers and wrapping
  "soft_wrap": "none",

  // Git
  "git": {
    "git_gutter": "tracked_files",
    "enable_diff": false,
  },

  // Visual
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "buffer_font_family": "Hack Nerd Font Mono",
  "relative_line_numbers": "enabled",
  "minimap": {
    "show": "always",
    "display_in": "all_editors",
    "thumb": "hover",
  },

  // Debugger
  "inlay_hints": {
    "enabled": false,
    "show_value_hints": false,
  },

  // Terminal
  "terminal": {
    "button": false,
    "copy_on_select": true,
    "dock": "right",
    "toolbar": {
      "breadcrumbs": false,
    },
  },

  // Languages
  "show_signature_help_after_edits": true,
  "languages": {
    "Plain Text": {
      "wrap_guides": [120],
      "preferred_line_length": 120,
      "soft_wrap": "bounded",
    },
    "C++": {
      "wrap_guides": [100],
      "preferred_line_length": 100,
      "soft_wrap": "bounded",
    },
    "Markdown": {
      "wrap_guides": [100],
      "preferred_line_length": 100,
      "soft_wrap": "bounded",
    },
    "JSONC": {
      "wrap_guides": [120],
      "preferred_line_length": 120,
      "tab_size": 2,
    },
    "CSharp": {
      "wrap_guides": [120],
      "preferred_line_length": 120,
    },
    "Python": {
      // pyright is so much better
      "wrap_guides": [88],
      "language_servers": ["!pylsp", "pyright"],
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["--stdin-filename", "{buffer_path}", "-"],
        },
      },
    },
  },
  "dap": {
    "lldb-dap": {
      "binary": "C:\\Program Files\\LLVM\\bin\\lldb-dap.exe",
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        // Disable inserting parameter placeholders when pressing tab
        "arguments": ["--function-arg-placeholders=0"],
      },
    },
    "rust-analyzer": {
      "settings": {
        // Disable inserting parameter placeholders when pressing tab
        "rust-analyzer.completion.callable.snippets": "add_parentheses",
      },
    },
  },

  // Extensions
  "auto_install_extensions": {
    // Lsps
    "html": true,
    "csharp": true,
    "neocmake": true,
    "codebook": true,

    // Themes
    "vscode-dark-modern": true,
    "modern-icons": true,
  },

  // Custom visual assist color theme
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "VSCode Dark Modern",
  },
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        // Force actual enum values to brown
        "token_type": "enumMember",
        "foreground_color": "#936228",
      },
      {
        // Force const variables (like `const int x = 5;`) to your variable color
        "token_type": "variable",
        "token_modifiers": ["readonly"],
        "foreground_color": "#b0b176",
      },
    ],
  },
  "theme_overrides": {
    "VSCode Dark Modern": {
      "syntax": {
        // Keywords
        "keyword": { "color": "#cf564d" },
        "keyword.operator": { "color": "#cf564d" },
        "namespace": { "color": "#c0ccb9" },
        "module": { "color": "#c0ccb9" },
        "attribute": { "color": "#c0ccb9" },

        // Types
        "type": { "color": "#efd630" },
        "type.builtin": { "color": "#cf564d" },
        "class": { "color": "#efd630" },
        "enum": { "color": "#efd630" },
        "interface": { "color": "#efd630" },
        "struct": { "color": "#efd630" },
        "typeParameter": { "color": "#efd630" },
        "boolean": { "color": "#b5cea8" },

        // String
        "punctuation.special": { "color": "#d4b273" },

        // Functions
        "function": { "color": "#d37f2a" },
        "function.decorator": { "color": "#c0ccb9" },
        "method": { "color": "#d37f2a" },
        "constructor": { "color": "#d37f2a" },

        // Constants
        "constant": { "color": "#936228" },
        "enumMember": { "color": "#936228" },
        "macro": { "color": "#b461c0" },
        "function.macro": { "color": "#b461c0" },
        "preproc": { "color": "#a2a2a2" },

        // Variables and fields
        "variable": { "color": "#b0b176" },
        "property": { "color": "#cdce87" },
        "parameter": { "color": "#b6a671" },
        "variable.special": { "color": "#cdce87" },

        // Markdown
        "title": { "color": "#d37f2a", "font_style": "italic" },
        "emphasis.strong": { "color": "#cf564d" },
        "emphasis": { "font_style": "italic", "color": "#cf564d" },
        "text.literal": { "color": "#ce9178" },
        "punctuation.list_marker": { "color": "#d7ba7d" },
        "link_text": { "color": "#b5cea8" },
        "link_uri": { "color": "#c0ccb9", "font_style": "italic" },
      },
    },
  },
}
